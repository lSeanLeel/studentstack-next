# --- Supabase (waitlist + elite subscribers) ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Admin ---
ADMIN_PASSWORD=change-me-to-something-long

# Copy this file to .env.local for local dev (see OPS_MANUAL.md).

# --- Newsletter generator (admin API route) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Weekly email cron (optional: POST /api/admin/cheat-sheet/cron) ---
CRON_SECRET=generate-a-long-random-string

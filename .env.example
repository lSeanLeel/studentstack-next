# --- Supabase (waitlist + elite subscribers + landing signups) ---
# Use either SUPABASE_URL or NEXT_PUBLIC_SUPABASE_URL for the project URL.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Beehiiv (public newsletter list) ---
BEEHIIV_API_KEY=your_beehiiv_api_key
BEEHIIV_PUBLICATION_ID=your_publication_uuid

# --- Admin ---
ADMIN_PASSWORD=change-me-to-something-long

# Copy this file to .env or .env.local for local dev (see OPS_MANUAL.md).

# --- Newsletter generator (admin API route) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Weekly email cron (optional: POST /api/admin/cheat-sheet/cron) ---
CRON_SECRET=generate-a-long-random-string
